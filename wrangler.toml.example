name = "movecar"
main = "movecar.js"
compatibility_date = "2024-01-01"
workers_dev = true

# 自定义域名路由（替换为你的域名）
routes = [
  { pattern = "movecar.example.com", zone_name = "example.com" }
]

# KV 存储绑定（替换为你的 KV namespace ID）
kv_namespaces = [
  { binding = "MOVE_CAR_STATUS", id = "YOUR_KV_NAMESPACE_ID" }
]

# 环境变量（非敏感配置）
[vars]
EMAIL_TO = "your-email@example.com"
EMAIL_FROM = "MoveCar <movecar@your-domain.com>"
PHONE_NUMBER = "your-phone-number"
# 海外开发/测试 IP 白名单，多个 IP 用英文逗号分隔；生产可留空或删除
TEST_IP_ALLOWLIST = "203.0.113.10,2001:db8::10"
# TG_BOT_TOKEN、TG_CHAT_ID、RESEND_API_KEY、DEBUG_KEY、AMAP_KEY 通过 wrangler secret 设置
# AMAP_KEY 可选：高德 Web服务 Key，用于在车主确认页显示提交者文字地址
